<Window x:Class="Minimoniclock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Minimoniclock.ViewModels"
        Title="minimoniclock"
        Width="400"
        Height="1280"
        MinWidth="320"
        MinHeight="180"
        Background="#050507"
        Foreground="#F7F7F2"
        FontFamily="Consolas"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        KeyDown="OnKeyDown"
        SizeChanged="OnSizeChanged">
  <Window.DataContext>
    <viewModels:ClockViewModel />
  </Window.DataContext>

  <Grid x:Name="Root" Background="#050507">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Margin="12"
            HorizontalAlignment="Right"
            Background="#1A1A20"
            CornerRadius="6"
            Opacity="0.82">
      <StackPanel Orientation="Horizontal">
        <ToggleButton x:Name="TopmostToggle"
                      Width="44"
                      Height="36"
                      Margin="2"
                      Content="TOP"
                      FontSize="12"
                      Foreground="#F7F7F2"
                      Background="#262630"
                      BorderBrush="#3A3A46"
                      ToolTip="Keep this window above other windows"
                      Checked="OnTopmostChanged"
                      Unchecked="OnTopmostChanged" />
        <Button Width="44"
                Height="36"
                Margin="2"
                Content="FIT"
                FontSize="12"
                Foreground="#F7F7F2"
                Background="#262630"
                BorderBrush="#3A3A46"
                ToolTip="Toggle borderless fit mode"
                Click="OnFitModeClicked" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" Margin="{Binding ClockMargin}">
      <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
        <TextBlock Text="{Binding TimeText}"
                   FontWeight="SemiBold"
                   FontSize="220"
                   LineHeight="220"
                   Foreground="#F7F7F2"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Viewbox>
    </Grid>

    <TextBlock Grid.Row="2"
               Margin="12"
               Text="{Binding LayoutLabel}"
               FontFamily="Segoe UI"
               FontSize="12"
               Foreground="#888895"
               HorizontalAlignment="Center" />
  </Grid>
</Window>
